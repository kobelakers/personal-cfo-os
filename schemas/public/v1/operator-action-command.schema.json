{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-cfo-os/schemas/public/v1/operator-action-command.schema.json",
  "title": "OperatorActionCommand",
  "description": "Canonical external write contract for controlled operator actions exposed through /api/v1.",
  "type": "object",
  "required": ["request_id", "actor"],
  "properties": {
    "request_id": { "type": "string" },
    "actor": { "type": "string" },
    "roles": { "type": "array", "items": { "type": "string" } },
    "note": { "type": "string" },
    "expected_version": { "type": "integer" },
    "graph_id": { "type": "string" }
  }
}
