{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskSpec",
  "type": "object",
  "required": ["id", "goal", "scope", "constraints", "risk_level", "success_criteria", "required_evidence", "approval_requirement", "user_intent_type", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "goal": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["areas"],
      "properties": {
        "areas": { "type": "array", "items": { "type": "string" } },
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "constraints": {
      "type": "object",
      "required": ["hard"],
      "properties": {
        "hard": { "type": "array", "items": { "type": "string" } },
        "soft": { "type": "array", "items": { "type": "string" } }
      }
    },
    "risk_level": { "type": "string", "enum": ["unknown", "low", "medium", "high", "critical"] },
    "success_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "reason", "mandatory"],
        "properties": {
          "type": { "type": "string" },
          "reason": { "type": "string" },
          "mandatory": { "type": "boolean" }
        }
      }
    },
    "approval_requirement": { "type": "string", "enum": ["none", "notify", "recommended", "mandatory"] },
    "deadline": { "type": "string", "format": "date-time" },
    "user_intent_type": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
